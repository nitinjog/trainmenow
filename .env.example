# Database (Neon serverless PostgreSQL in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trainmenow

# Redis (Upstash in production)
REDIS_URL=redis://localhost:6379

# Gemini API - user provides their own key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# Search
SERPAPI_KEY=

# App
PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Frontend (set to Netlify URL in production)
FRONTEND_URL=http://localhost:5173
